# ════════════════════════════════════════════════════
# Enterprise GenAI Platform — Environment Configuration
# Copy this to .env and fill in your real values.
# NEVER commit .env to version control.
# ════════════════════════════════════════════════════

# ── Application ─────────────────────────────────────
APP_NAME=Enterprise GenAI Platform
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO
STRUCTURED_LOG_FORMAT=false

# ── API Security ─────────────────────────────────────
PLATFORM_API_KEY=dev-secret-key-change-in-production

# ── LLM Provider ─────────────────────────────────────
# Options: openai | anthropic | azure_openai | local
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...your-key-here...
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.0
OPENAI_MAX_TOKENS=2048

# Anthropic (optional)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-haiku-20240307

# Azure OpenAI (optional)
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_API_VERSION=2024-02-01

# Local Ollama (optional)
# LOCAL_LLM_BASE_URL=http://localhost:11434
# LOCAL_LLM_MODEL=llama3

# ── Embedding ─────────────────────────────────────────
# Options: sentence_transformers | openai | azure_openai
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ── Vector Store ──────────────────────────────────────
FAISS_INDEX_PATH=./data/faiss_index
FAISS_TOP_K=5
ENABLE_HYBRID_SEARCH=false

# ── Database ─────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://genai:genai@localhost:5432/genai_db
DUCKDB_PATH=./data/analytical.duckdb

# ── Redis ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_TTL_SECONDS=3600
ENABLE_RESPONSE_CACHE=true

# ── MLflow ───────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=genai-platform

# ── Chunking ─────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Agent ────────────────────────────────────────────
AGENT_MAX_ITERATIONS=10
AGENT_TIMEOUT_SECONDS=120

# ── Guardrails ────────────────────────────────────────
ENABLE_PII_DETECTION=true
ENABLE_CONTENT_FILTER=true
MAX_INPUT_LENGTH=4096

# ── Cost Tracking ─────────────────────────────────────
COST_PER_1K_INPUT_TOKENS=0.00015
COST_PER_1K_OUTPUT_TOKENS=0.0006
MONTHLY_BUDGET_USD=100.0
